# ---------- Arc Testnet ----------
ARC_RPC_URL=https://rpc.testnet.arc.network
ARC_WS_URL=wss://rpc.testnet.arc.network
ARC_CHAIN_ID=5042002
ARC_EXPLORER=https://testnet.arcscan.app

# USDC on Arc testnet (6 decimals, also the gas token)
USDC_ADDRESS=0x3600000000000000000000000000000000000000

# Filled in after deploying StampEscrow.sol via Remix
STAMP_ESCROW_ADDRESS=0x0A027767aC1e4aA5474A1B98C3eF730C3994E67b

# ---------- Circle Developer-Controlled Wallets ----------
# Get from https://console.circle.com
CIRCLE_API_KEY=TEST_API_KEY:...
CIRCLE_ENTITY_SECRET=
CIRCLE_WALLET_SET_ID=

# Circle blockchain identifier for Arc testnet (confirmed from Circle docs)
CIRCLE_BLOCKCHAIN=ARC-TESTNET

# ---------- Database (TiDB Cloud, MySQL-compatible) ----------
DATABASE_URL=mysql://user:pass@gateway.tidbcloud.com:4000/stamp?ssl={"rejectUnauthorized":true}

# ---------- Auth ----------
AUTH_SECRET=change-me-run-openssl-rand-base64-32
AUTH_TRUST_HOST=true

# ---------- LLM (Gemini preferred when GEMINI_API_KEY is set) ----------
GEMINI_API_KEY=
GEMINI_MODEL=gemini-3.1-flash-lite-preview

# Fallback OpenAI-compatible endpoint (used only when GEMINI_API_KEY is empty)
LLM_BASE_URL=https://api.z.ai/api/paas/v4
LLM_API_KEY=
LLM_MODEL=glm-5.1

# ---------- Protocol treasury (receives forfeit fees) ----------
FEE_SINK_ADDRESS=0x6Bd07000C5F746af69BEe7f151eb30285a6678B2
